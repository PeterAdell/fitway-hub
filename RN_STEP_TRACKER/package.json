{
  "name": "react-native-step-tracker",
  "version": "1.0.0",
  "description": "Offline device-sensor based step tracking with GPS route mapping (Android/iOS) — no paid APIs",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "build:android": "cd android && ./gradlew assembleDebug",
    "build:ios": "xcodebuild -workspace ios/RNStepTracker.xcworkspace -scheme RNStepTracker -configuration Debug"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-native": "^0.73.0",
    "react-native-maps": "^1.7.1",
    "react-native-geolocation-service": "^5.3.1",
    "@react-native-async-storage/async-storage": "^1.21.0",
    "react-native-permissions": "^4.1.5",
    "react-native-sensors": "^7.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "typescript": "^5.0.0",
    "eslint": "^8.40.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.70.0"
  },
  "keywords": [
    "react-native",
    "step-tracking",
    "pedometer",
    "offline",
    "GPS",
    "fitness"
  ],
  "license": "MIT"
}
